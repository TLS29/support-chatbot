{
  "name": "@support-chatbot/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "imports": {
    "#domain/*": "./src/domain/*.ts",
    "#application/*": "./src/application/*.ts",
    "#infrastructure/*": "./src/infrastructure/*.ts",
    "#interfaces/*": "./src/interfaces/*.ts"
  },
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsup",
    "start": "node dist/main.js",
    "lint:deps": "depcruise 'src/**/*.ts' --config .dependency-cruiser.cjs"
  },
  "dependencies": {
    "@google/genai": "^2.7.0",
    "@support-chatbot/shared": "workspace:*",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "pino": "^9.5.0",
    "pino-http": "^11.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "dependency-cruiser": "^16.0.0",
    "pino-pretty": "^11.3.0",
    "tsup": "^8.3.5",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  }
}
