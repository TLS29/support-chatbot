{
  "name": "support-chatbot",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.10.0",
  "scripts": {
    "dev:api": "pnpm --filter @support-chatbot/api dev",
    "dev:widget": "pnpm --filter @support-chatbot/widget dev",
    "build": "pnpm -r --parallel build",
    "lint:deps": "pnpm --filter @support-chatbot/api lint:deps",
    "ingest": "pnpm --filter @support-chatbot/api ingest"
  }
}
