# CHROMA_URL=http://localhost:8000     # Epic 02
# SIMILARITY_THRESHOLD=0.3              # Epic 02
# RATE_LIMIT_PER_MIN=10                 # Epic 01
# MAX_HISTORY_MESSAGES=40               # Epic 01